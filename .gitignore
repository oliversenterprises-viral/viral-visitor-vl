.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vercel
.env*

# Agent/session artifacts (not product source)
playwright-report/
test-results/
terminals/
agent-tools/
mcps/
_premium_recovered/
marketing/
public/.well-known/

