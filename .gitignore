# ============================================================================
# Sentinel Key Purge: Secrets Hygiene
# NEVER commit real environment variables, keys, passwords, or JWTs.
# Use .env.example as the ONLY committed template (placeholders only).
# ============================================================================

# Environment / Secrets (critical — block all real .env files)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.* 
!.env.example
*.env

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vercel
.env*
