{
  "name": "viralrefer-premium",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,css,html}\"",
    "supabase:local": "supabase start",
    "supabase:push": "supabase db push",
    "edge:deploy": "supabase functions deploy --all",
    "edge:dev": "supabase functions serve",
    "perf:analyze": "npx vite-bundle-visualizer",
    "perf:lighthouse": "npx lighthouse http://localhost:5173 --output=html --output-path=./lighthouse-report.html"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.8.0",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "eslint": "^10.4.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.1.6"
  }
}
