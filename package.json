{
  "name": "viralrefer-premium",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:audit": "node tests/site-audit.mjs",
    "test:smoke:prod": "node scripts/smoke-prod-referrals.mjs",
    "test:admin-audit": "node scripts/audit-admin-flow.mjs",
    "test:preview-load": "node tests/preview-load.mjs",
    "deploy:prod": "node scripts/deploy-prod.mjs",
    "optimizer:autopilot": "node scripts/run-optimizer-autopilot.mjs",
    "optimizer:autopilot:dry": "node scripts/run-optimizer-autopilot.mjs --dry-run",
    "growth:queue": "node scripts/generate-growth-post-queue.mjs",
    "growth:post": "node scripts/post-growth-queue.mjs",
    "dba:apply-migration": "node scripts/dba-apply-migration.mjs",
    "dba:migration-repair": "node scripts/dba-migration-repair.mjs",
    "dba:inventory": "node scripts/dba-inventory.mjs",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,css,html}\"",
    "supabase:local": "supabase start",
    "supabase:push": "supabase db push",
    "edge:deploy": "supabase functions deploy --all",
    "edge:dev": "supabase functions serve",
    "perf:analyze": "npx vite-bundle-visualizer",
    "perf:lighthouse": "npx lighthouse http://localhost:5173 --output=html --output-path=./lighthouse-report.html"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^25.8.0",
    "canvas-confetti": "^1.9.4",
    "chart.js": "^4.5.1",
    "eslint": "^10.4.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.12",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "sharp": "^0.35.2"
  }
}
